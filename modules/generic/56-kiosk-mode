#!/bin/bash
set -xe
export LC_ALL=C

########################################
# Functions and Basic Configuration    #
########################################

# Load common functions and set up cleanup trap
source /common.sh
install_cleanup_trap

# Load additional configuration (e.g., BASE_USER)
source /files/00-config

########################################
# Configuration                        #
########################################

echo "Setting up Kiosk Mode for Touch Display"

# Install dependencies for kiosk mode
DEPS=(
    xserver-xorg
    x11-xserver-utils
    xinit
    openbox
    chromium
    unclutter
)

echo "Installing kiosk mode dependencies"
apt-get install --yes "${DEPS[@]}"

########################################
# Configure Autologin                  #
########################################

echo "Setting up autologin for ${BASE_USER}"

# Create systemd override directory for getty@tty1
mkdir -p /etc/systemd/system/getty@tty1.service.d

# Configure autologin for the main user on tty1
cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf << EOF
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin ${BASE_USER} --noclear %I \$TERM
EOF

########################################
# Create Kiosk Startup Script          #
########################################

echo "Creating kiosk startup script"

# Create .xinitrc for the user to start kiosk mode
cat > /home/${BASE_USER}/.xinitrc << 'EOF'
#!/bin/bash

# Disable screen blanking and power management
xset s off
xset -dpms
xset s noblank

# Hide mouse cursor when idle
unclutter -idle 0.1 &

# Start openbox window manager
openbox &

# Wait for X server to be ready
sleep 2

# Start chromium in kiosk mode pointing to local Mainsail
chromium \
    --kiosk \
    --noerrdialogs \
    --disable-infobars \
    --no-first-run \
    --enable-features=OverlayScrollbar \
    --start-maximized \
    --disable-translate \
    --disable-features=TranslateUI \
    --disk-cache-dir=/tmp/chromium-cache \
    http://localhost &

# Keep the X session alive
wait
EOF

chmod +x /home/${BASE_USER}/.xinitrc
chown ${BASE_USER}:${BASE_USER} /home/${BASE_USER}/.xinitrc

########################################
# Configure Auto-start X on Login      #
########################################

echo "Configuring conditional auto-start of X server"

# Add conditional startx to .bash_profile - only starts if display is detected
cat >> /home/${BASE_USER}/.bash_profile << 'EOF'

# Start X server automatically on tty1 for kiosk mode if display is available
if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
    # Check if a display is connected before starting X
    if [ -e /dev/fb0 ] || [ -d /sys/class/drm/card0 ]; then
        startx
    fi
fi
EOF

chown ${BASE_USER}:${BASE_USER} /home/${BASE_USER}/.bash_profile

########################################
# Create Kiosk Helper Scripts          #
########################################

echo "Creating kiosk mode helper scripts"

# Create disable-kiosk script for users who want to disable auto-start
cat > /usr/local/bin/disable-kiosk << 'DISABLE_EOF'
#!/bin/bash
# Disable automatic kiosk mode startup for MainsailOS

BASE_USER="pi"

echo "Disabling automatic kiosk mode startup..."

# Remove autologin configuration
rm -f /etc/systemd/system/getty@tty1.service.d/autologin.conf
rmdir /etc/systemd/system/getty@tty1.service.d 2>/dev/null || true

# Remove X autostart from .bash_profile
if [ -f /home/${BASE_USER}/.bash_profile ]; then
    sed -i '/# Start X server automatically on tty1 for kiosk mode/,/^fi$/d' /home/${BASE_USER}/.bash_profile
fi

systemctl daemon-reload

echo "Kiosk mode auto-start disabled. Please reboot for changes to take effect."
echo "Note: You can still manually start kiosk mode by running 'startx' after logging in."
DISABLE_EOF

chmod +x /usr/local/bin/disable-kiosk

echo "Kiosk mode setup completed"
echo "Kiosk mode will automatically start when a display is detected"
echo "To disable automatic kiosk mode, run: sudo disable-kiosk"
